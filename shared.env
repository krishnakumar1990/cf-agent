# Shared cf-agent configuration
# Distribute this file to your team.
#
# Each user must supply their own:
#   - ADOBE_CLIENT_ID      (from their Adobe Developer Console OAuth app)
#   - ADOBE_CLIENT_SECRET  (from their Adobe Developer Console OAuth app)
#
# After login, cf-agent will prompt the user to select PROD / STAGE / DEV.
#
# Run: cf-agent login --preset shared.env

ADOBE_SCOPES=openid,AdobeID,aem.fragments.management,aem.folders
ADOBE_REDIRECT_URI=https://aem-agent-callback.vercel.app/callback
